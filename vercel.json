{
  "rewrites": [
    {
      "source": "/api/api/:path*",
      "destination": "https://safespace-api.duckdns.org/api/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "https://safespace-api.duckdns.org/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}